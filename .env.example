# ── Supabase ──────────────────────────────────────────────────────────────────
# Your project URL (found in: Supabase Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co

# Publishable (anon) key – safe to expose in the browser
# Found in: Supabase Dashboard → Project Settings → API → Project API keys
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_<your-key>

# ── Google Gemini ─────────────────────────────────────────────────────────────
# API key for Gemini (used for OCR / document processing)
# Get one at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=<your-gemini-api-key>


# ── Google Cloud Text-to-Speech ───────────────────────────────────────────────
# Create one at: https://console.cloud.google.com/iam-admin/serviceaccounts
# GOOGLE_TTS_CREDENTIALS_JSON={"type":"service_account","project_id":"your-project","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@your-project.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"...","universe_domain":"googleapis.com"}
GOOGLE_TTS_CREDENTIALS_JSON=


# ── DeepL Translation ─────────────────────────────────────────────────────────
# API key for DeepL (used for UI string translation)
# Get one at: https://www.deepl.com/pro-api
DEEPL_KEY=<your-deepl-api-key>
